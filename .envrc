watch_file .nix/flake.nix
watch_file .nix/flake.lock
use flake ./.nix

# Tier 1: DP bootstrap + learned EPV + climb curriculum
export DD_SOCCER_ENABLE_DP_BOOTSTRAP=true
export DD_SOCCER_DP_BOOTSTRAP_HORIZON=64
export DD_SOCCER_DP_BOOTSTRAP_SWEEPS=200
export SOCCER_APPROX_DP_REPLAY_PASSES=8
export DD_SOCCER_ENABLE_LEARNED_EPV=true
export DD_SOCCER_LEARNED_EPV_GRID_PATH=/tmp/epv-export/epv_grid.json
export DD_SOCCER_ENABLE_TARGET_STANDARDIZATION=true
export DD_SOCCER_FORWARD_PASS_CLIMB_CURRICULUM=true
export DD_SOCCER_ENABLE_NEURAL_SELF_BOOTSTRAP=true
export DD_SOCCER_ENABLE_MAXA_BOOTSTRAP=true
